      <div class="stat-item">
        <div class="stat-num">47<span>+</span></div>
        <div class="stat-label">\u041f\u0440\u043e\u0435\u043a\u0442\u043e\u0432</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">\u20bd12<span>\u041c</span></div>
        <div class="stat-label">\u041e\u0441\u0432\u043e\u0435\u043d\u043e \u0431\u044e\u0434\u0436\u0435\u0442\u043e\u0432</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">3.2<span>x</span></div>
        <div class="stat-label">\u0421\u0440\u0435\u0434\u043d\u0438\u0439 ROAS</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">2<span>\u0433.</span></div>
        <div class="stat-label">\u041e\u043f\u044b\u0442\u0430</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="services-bg" id="services">
  <div class="section-label">\u0423\u0441\u043b\u0443\u0433\u0438</div>
  <div class="section-title">\u0427\u0442\u043e \u044f \u0434\u0435\u043b\u0430\u044e</div>
  <div class="services-grid reveal">
    <div class="service-card">
